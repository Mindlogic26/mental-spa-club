{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "functions": {
    "api/index.py": { "runtime": "@vercel/python" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/index.py" },
    { "source": "/mirror", "destination": "api/index.py" },
    { "source": "/", "destination": "api/index.py" }
  ]
}